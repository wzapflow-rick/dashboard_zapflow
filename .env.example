# =======================================
#  VARIÁVEIS DE AMBIENTE OBRIGATÓRIAS
# =======================================

# Chave secreta para assinatura de JWT (mínimo 32 caracteres)
JWT_SECRET=sua_chave_secreta_aqui_minimo_32_caracteres

# URL de conexão com o PostgreSQL
# Formato: postgresql://usuario:senha@host:porta/database
DATABASE_URL=postgresql://postgres:senha@localhost:5432/cardapio

# Modo de ambiente (production ou development)
NODE_ENV=production

# =======================================
#  CONFIGURAÇÕES OPCIONAIS
# =======================================

# Desativar HMR em desenvolvimento (para AI Studio)
DISABLE_HMR=false

# =======================================
#  INTEGRAÇÕES
# =======================================

# Chave secreta compartilhada com o N8N (para webhooks)
N8N_WEBHOOK_SECRET=

# Chave da API do Google Maps (para cálculo de rotas e geocoding)
GOOGLE_MAPS_API_KEY=

# =======================================
#  MERCADO PAGO
# =======================================

# Access Token do Mercado Pago (obtenha em: https://dashboard.mercadopago.com.br/developers)
MP_ACCESS_TOKEN=

# Public Key do Mercado Pago (para SDK JS no frontend)
MP_PUBLIC_KEY=

# Token para servidor MCP do Mercado Pago (mesmo token do MP_ACCESS_TOKEN)
MERCADO_PAGO_MCP_TOKEN=

# =======================================
#  NOTAS SOBRE O BANCO DE DADOS
# =======================================
# O sistema usa PostgreSQL diretamente via lib/postgres.ts
# Todos os nomes de tabelas estão centralizados em lib/tables.ts
# 
# MIGRAÇÃO DO NOCODB:
# - lib/nocodb.ts foi substituído por lib/postgres.ts
# - Todas as actions agora usam 'import { pg } from "@/lib/postgres"'
# - A interface é similar: pg.list(), pg.findById(), pg.create(), pg.update(), etc.
