# =======================================
#  VARIÁVEIS DE AMBIENTE OBRIGATÓRIAS
# =======================================

# Chave secreta para assinatura de JWT (mínimo 32 caracteres)
JWT_SECRET=sua_chave_secreta_aqui_minimo_32_caracteres

# URL completa do NocoDB (ex: https://db.wzapflow.com.br)
NOCODB_URL=https://db.wzapflow.com.br

# Token de acesso da API do NocoDB
NOCODB_TOKEN=seu_token_de_acesso

# Modo de ambiente (production ou development)
NODE_ENV=production

# =======================================
#  CONFIGURAÇÕES OPCIONAIS
# =======================================

# Desativar HMR em desenvolvimento (para AI Studio)
DISABLE_HMR=false

# =======================================
#  INTEGRAÇÕES
# =======================================

# Chave secreta compartilhada com o N8N (para webhooks)
N8N_WEBHOOK_SECRET=

# Chave da API do Google Maps (para cálculo de rotas e geocoding)
GOOGLE_MAPS_API_KEY=

# =======================================
#  MERCADO PAGO
# =======================================

# Access Token do Mercado Pago (obtenha em: https://dashboard.mercadopago.com.br/developers)
MP_ACCESS_TOKEN=

# Public Key do Mercado Pago (para SDK JS no frontend)
MP_PUBLIC_KEY=

# Token para servidor MCP do Mercado Pago (mesmo token do MP_ACCESS_TOKEN)
MERCADO_PAGO_MCP_TOKEN=

# =======================================
#  NOTAS SOBRE O NOCODB
# =======================================
# Todos os IDs de tabelas agora estão centralizados em lib/constants.ts
# Não é mais necessário definir IDs de tabelas no .env
